# Sanity (project lives in .env.local — never commit secrets)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_REVALIDATE_SECRET=

# Resend (https://resend.com — required for real inquiry + newsletter delivery)
RESEND_API_KEY=
# Segment ID from https://resend.com/audience?segmentId=... (env name kept for compatibility)
RESEND_AUDIENCE_ID=
INQUIRY_TO_EMAIL=hello@bilgewatermkt.com
INQUIRY_FROM_EMAIL=inquiries@bilgewatermkt.com
